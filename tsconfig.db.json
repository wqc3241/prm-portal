{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "outDir": "./dist-db",
    "rootDir": ".",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "moduleResolution": "node",
    "declaration": false,
    "sourceMap": false
  },
  "include": ["knexfile.ts", "migrations/**/*.ts", "seeds/**/*.ts"]
}
