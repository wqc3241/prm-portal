{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "types": ["node", "cors", "express", "jsonwebtoken", "bcryptjs", "morgan", "uuid", "node-cron"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "migrations", "seeds", "tests"],
  "ts-node": {
    "transpileOnly": true
  }
}
